# --- Lead / contact form emails (Resend) ---
# Create a key at https://resend.com — free tier available.
# Verify your sending domain in Resend and use an address on that domain, e.g.:
#   EMAIL_FROM="Perfect RMC <noreply@perfectrmc.in>"
# For Resend’s test domain during development only:
#   EMAIL_FROM="onboarding@resend.dev"
RESEND_API_KEY=

EMAIL_FROM=

# Test mode (recommended while domain is not verified in Resend)
# 1) Keep EMAIL_FROM=onboarding@resend.dev
# 2) Set LEAD_EMAIL_TEST_MODE=true
# 3) Set LEAD_TEST_RECIPIENT to your own Resend account inbox
# In test mode, all form summaries go only to LEAD_TEST_RECIPIENT and customer auto-reply is skipped.
LEAD_EMAIL_TEST_MODE=false
# LEAD_TEST_RECIPIENT=yourname@example.com

# Optional: set to "false" to stop sending customer confirmation emails (team notifications still sent).
# SEND_CUSTOMER_ACK=true

